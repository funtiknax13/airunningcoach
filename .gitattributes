# Все текстовые файлы — всегда LF (Unix) в репозитории и при checkout
* text=auto eol=lf

# Явно — критичные файлы
*.html      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.vue       text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.conf      text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
*.env       text eol=lf
*.ini       text eol=lf

# Бинарные — не трогать
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.gpx       binary
*.fit       binary
