# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=runcoach
POSTGRES_USER=runcoach
POSTGRES_PASSWORD=change_me_strong_password

# Собирается автоматически из переменных выше
DATABASE_URL=postgresql://runcoach:change_me_strong_password@postgres:5432/runcoach

# ── Безопасность ──────────────────────────────────────────────
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_random_secret

# ── Email (Gmail SMTP) ────────────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM_NAME=AIRunningCoach

# ── Приложение ────────────────────────────────────────────────
APP_BASE_URL=https://yourdomain.com

# ── AI ────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...

# ── Google OAuth ──────────────────────────────────────────────
# Получить на https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client IDs
# Тип: Web application
# Authorized redirect URIs: https://yourdomain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── ЮКасса ───────────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://airunningcoach.pro/payment/success

# ── Nginx ────────────────────────────────────────────────────
NGINX_PORT=80
